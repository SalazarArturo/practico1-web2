<%- include('../../components/home/header.ejs') %>
    <div class="container mt-4">

        <h2>
            <%= locals.isEdit ? 'Editar modelo': 'Nuevo modelo de cancha' %>
        </h2>

        
        <% if(locals.error){ %>
            <p class="text-danger mt-2"><%= error %></p>
        <% } %> 

        <form action="<%= locals.isEdit ? `/user/admin/modelos/${locals.modelo.id}` : "/user/admin/modelos" %>" method="post">

            <div class="mb-3">
                <label class="form-label">Nombre del modelo</label> 
                <input type="text" name="nombre" class="form-control" placeholder="Ej: Fútbol, Tenis, Padel" value="<%= locals.modelo? `${locals.modelo.nombre}` : '' %>">
            </div>
            <button type="submit" class="btn btn-success">
                Guardar
            </button>
            <a href="/user/admin/modelos" class="btn btn-secondary">
                Cancelar
            </a>
        </form>
    </div>
<%- include('../../components/home/footer.ejs') %>