<%- include('../../components/home/header.ejs') %>

<div class="container mt-4">
    <h2>Gestión de Canchas</h2>

    <% if (locals.error) { %>
        <p class="text-danger mt-2"><%= error %></p>
    <% } %>

    <% if (!error && canchas.length === 0) { %>
        <p class="text-muted mt-2">No hay canchas registradas todavia</p>
    <% } %>

    <a href="/user/admin/canchas/new" class="btn btn-primary mb-3 mt-2">
        + Crear nueva cancha
    </a>

    <% if (!error && canchas.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Precio/hora</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% canchas.forEach(cancha => { %>
                        <tr>
                            <td><%= cancha.nombre %></td>
                            <td><%= cancha.tipoCancha?.nombre || '-' %></td>
                            <td>$<%= cancha.precio_por_hora %></td>
                            <td>
                                <% if (cancha.estado === 'activa') { %>
                                    <span class="badge bg-success">Activa</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Inactiva</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/user/admin/canchas/<%= cancha.id %>/horarios"
                                   class="btn btn-info btn-sm">
                                    Horarios
                                </a>
                                <a href="/user/admin/canchas/<%= cancha.id %>/edit"
                                   class="btn btn-warning btn-sm">
                                    Editar
                                </a>
                                <form action="/user/admin/canchas/<%= cancha.id %>/delete"
                                      method="POST"
                                      style="display:inline;"
                                      onsubmit="return confirm('¿Eliminar esta cancha?')">
                                    <button class="btn btn-danger btn-sm">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../../components/home/footer.ejs') %>
