<%- include('../../components/home/header.ejs') %>
   

<div class="container mt-4">

    <h2>Gestion de Canchas</h2>

    <!-- 🔴 Caso 1: Error -->
    <% if(error){ %>
        <p class="text-danger mt-2"><%= error %></p>
    <% } %>

    <!-- 🟡 Caso 2: No hay canchas -->
    <% if(!error && canchas.length === 0){ %>
        <p class="text-muted mt-2">No hay canchas registradas todavia</p>
    <% } %>

    <!-- 🟢 Botón crear (siempre visible) -->
    <a href="/user/admin/canchas/new" class="btn btn-primary mb-3">
        Crear nueva cancha
    </a>

    <!-- 🟢 Caso 3: Hay canchas -->
    <% if(!error && canchas.length > 0){ %>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                <% canchas.forEach(cancha => { %>
                    <tr>
                        <td><%= cancha.nombre %></td>
                        <td><%= cancha.precio_por_hora %></td>
                        <td>
                            <% if(cancha.estado === 'activa'){ %>
                                <span class="badge bg-success">Activa</span>
                            <% } else { %>
                                <span class="badge bg-secondary">Inactiva</span>
                            <% } %>
                        </td>
                        <td>
                            <a href="/admin/canchas/<%= cancha.id %>/edit" 
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>
                            <form action="/admin/canchas/<%= cancha.id %>/delete" 
                                  method="POST" 
                                  style="display:inline;">
                                <button class="btn btn-danger btn-sm">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>
<%- include('../../components/home/footer.ejs') %>