<%- include('../../components/home/header.ejs') %>

<div class="container mt-4">
    <h2 class="mb-4">Gestión de Reservas</h2>

    <% if (locals.error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (!reservas || reservas.length === 0) { %>
        <div class="alert alert-info">No hay reservas registradas.</div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Cancha</th>
                        <th>Fecha</th>
                        <th>Horario</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <% reservas.forEach((reserva, i) => { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= reserva.usuario?.nombre || '-' %></td>
                            <td><%= reserva.cancha?.nombre || '-' %></td>
                            <td><%= reserva.fecha || '-' %></td>
                            <td>
                                <%= reserva.hora_inicio ? reserva.hora_inicio.slice(0,5) : '-' %>
                                –
                                <%= reserva.hora_fin ? reserva.hora_fin.slice(0,5) : '-' %>
                            </td>
                            <td>
                                <% if (reserva.estado === 'confirmada') { %>
                                    <span class="badge bg-success">Confirmada</span>
                                <% } else if (reserva.estado === 'cancelada') { %>
                                    <span class="badge bg-danger">Cancelada</span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><%= reserva.estado %></span>
                                <% } %>
                            </td>
                            <td>
                                <form action="/user/admin/reservas/<%= reserva.id %>/estado" method="POST" class="d-flex gap-1">
                                    <select name="estado" class="form-select form-select-sm">
                                        <option value="confirmada" <%= reserva.estado === 'confirmada' ? 'selected' : '' %>>Confirmada</option>
                                        <option value="cancelada"  <%= reserva.estado === 'cancelada'  ? 'selected' : '' %>>Cancelada</option>
                                        <option value="completada" <%= reserva.estado === 'completada' ? 'selected' : '' %>>Completada</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../../components/home/footer.ejs') %>
