<%- include('../components/home/header.ejs') %>

<div class="container mt-4">
    <h1 class="mb-4">Canchas disponibles</h1>

    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (canchas.length === 0) { %>
        <div class="alert alert-info">No hay canchas disponibles por el momento.</div>
    <% } %>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <% canchas.forEach(cancha => { %>
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= cancha.nombre %></h5>
                        <p class="card-text">
                            <span class="badge bg-secondary mb-2"><%= cancha.tipoCancha?.nombre || 'Sin tipo' %></span><br>
                            <strong>Precio por hora:</strong> $<%= cancha.precio_por_hora %><br>
                            <strong>Estado:</strong>
                            <% if (cancha.estado === 'activa') { %>
                                <span class="badge bg-success">Activa</span>
                            <% } else { %>
                                <span class="badge bg-danger">Inactiva</span>
                            <% } %>
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="/cliente/canchas/<%= cancha.id %>/horarios" class="btn btn-primary w-100">
                            Ver disponibilidad
                        </a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('../components/footer.ejs') %>