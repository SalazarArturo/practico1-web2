<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReservasYa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .badge-estado-confirmada { background-color: #198754; }
        .badge-estado-cancelada  { background-color: #dc3545; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
    <a href="/user/home" class="navbar-brand">⚽ ReservasYa</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
            <% if (locals.userData) { %>
                <% if (locals.userData.rol === 'admin') { %>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Admin</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/user/admin/canchas">Canchas</a></li>
                            <li><a class="dropdown-item" href="/user/admin/modelos">Tipos de cancha</a></li>
                            <li><a class="dropdown-item" href="/user/admin/reservas">Reservas</a></li>
                            <li><a class="dropdown-item" href="/user/admin/resenas">Reseñas</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/cliente/canchas">Canchas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/cliente/reservas">Mis Reservas</a>
                    </li>
                <% } %>
            <% } %>
        </ul>

        <div class="d-flex align-items-center gap-3">
            <% if (locals.userData) { %>
                <span class="text-white-50 small">
                    <%= locals.userData.nombre %>
                    <span class="badge bg-secondary ms-1"><%= locals.userData.rol %></span>
                </span>
            <% } %>
            <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="btn btn-outline-light btn-sm">Cerrar sesión</button>
            </form>
        </div>
    </div>
</nav>
