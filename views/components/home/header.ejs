<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReservasYa</title>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</head>

<body>

<nav class="navbar navbar-dark bg-dark px-4">
   
    <a href="/user/home" class="navbar-brand text-white text-decoration-none">ReservasYa</a>
    
    <div class="d-flex align-items-center gap-3">
        <span class="text-white">
            Bienvenido, <%= userData?.nombre || 'Usuario' %>
        </span>
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <% if (locals.userData) { %>  
                <ul class="dropdown-menu">
                                <!-- Links de Cliente -->
                    <li class="nav-item">
                        <a class="dropdown-item" href="/cliente/canchas">Canchas</a>
                    </li>
                    <li class="nav-item">
                        <a class="dropdown-item" href="/cliente/reservas">Mis Reservas</a>
                    </li>
            </ul>
            <% } else { %>
                <li class="nav-item">
                    <a class="nav-link" href="/">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/register">Registrarse</a>
                </li>
            <% } %>
        </ul>


        <form action="/logout" method="POST" class="m-0">
            <button type="submit" class="btn btn-outline-light btn-sm">
                Logout
            </button>
        </form>
    </div>
</nav>